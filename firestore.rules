rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the owner can write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Books — only members can read; only owner can create/update/archive
    match /books/{bookId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.memberIds;

      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid
                    && request.auth.uid in request.resource.data.memberIds;

      allow update: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;

      // Transactions — accessible by book members
      match /transactions/{transactionId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/books/$(bookId)).data.memberIds;
      }

      // Categories — accessible by book members
      match /categories/{categoryId} {
        allow read, write: if request.auth != null
                           && request.auth.uid in get(/databases/$(database)/documents/books/$(bookId)).data.memberIds;
      }
    }
  }
}
